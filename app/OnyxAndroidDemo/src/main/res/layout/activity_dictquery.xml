<?xml version="1.0" encoding="utf-8"?>
<layout>

    <data>

        <variable
            name="activityDictQuery"
            type="com.android.onyx.demo.DictionaryActivity" />
    </data>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/edittext_keyword"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/dict_query_keyword_hint"
                android:minHeight="40dp" />

            <Button
                android:id="@+id/button_query"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="40dp"
                android:onClick="@{activityDictQuery::onClick}"
                android:text="@string/dict_query_button" />
        </LinearLayout>

        <Spinner
            android:id="@+id/spinner_dict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/btn_dropdown"
            android:minHeight="@dimen/dict_spinner_min_height"
            android:paddingStart="@dimen/dict_spinner_padding_horizontal"
            android:paddingEnd="@dimen/dict_spinner_padding_horizontal"
            android:spinnerMode="dropdown"
            android:visibility="gone" />

        <WebView
            android:id="@+id/webview_result"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
    </LinearLayout>
</layout>
